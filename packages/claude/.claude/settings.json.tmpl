{
  "permissions": {
    "allow": {{CLAUDE_PERMISSIONS_ALLOW}},
    "ask": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(chgrp *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(umount *)",
      "Bash(fdisk *)",
      "Bash(diskutil *)",
      "Bash(dd *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); cd \"$dir\" 2>/dev/null || true; branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); dirty=$(git status --porcelain 2>/dev/null); if [ -n \"$branch\" ]; then if [ -n \"$dirty\" ]; then printf '\\033[32m➜\\033[0m \\033[36m%s\\033[0m \\033[34mgit:(\\033[31m%s\\033[34m) \\033[33m✗\\033[0m' \"$(basename \"$dir\")\" \"$branch\"; else printf '\\033[32m➜\\033[0m \\033[36m%s\\033[0m \\033[34mgit:(\\033[31m%s\\033[34m)\\033[0m' \"$(basename \"$dir\")\" \"$branch\"; fi; else printf '\\033[32m➜\\033[0m \\033[36m%s\\033[0m' \"$(basename \"$dir\")\"; fi"
  },
  "model": "{{CLAUDE_MODEL}}",
  "skipDangerousModePermissionPrompt": true
}
