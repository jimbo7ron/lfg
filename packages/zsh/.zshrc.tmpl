# ZSH configuration
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="{{ZSH_THEME}}"
plugins=({{ZSH_PLUGINS}})

# Pick up tool-provided completions (e.g. rustup, gh)
fpath+=~/.zfunc

[ -f "$ZSH/oh-my-zsh.sh" ] && source "$ZSH/oh-my-zsh.sh"

# Prepend short hostname to robbyrussell prompt
PROMPT="%{$fg[yellow]%}%m%{$reset_color%} $PROMPT"

# Vi-mode line editing with [NORMAL]/[INSERT] indicator on the right.
# Initialise RPROMPT here so the very first prompt shows [INSERT];
# the zle-* widgets keep it in sync on mode switches thereafter.
bindkey -v
RPROMPT="%{$fg[green]%}[INSERT]%{$reset_color%}"
function zle-line-init zle-keymap-select {
  case $KEYMAP in
    vicmd)      RPROMPT="%{$fg[red]%}[NORMAL]%{$reset_color%}" ;;
    main|viins) RPROMPT="%{$fg[green]%}[INSERT]%{$reset_color%}" ;;
  esac
  zle reset-prompt
}
zle -N zle-line-init
zle -N zle-keymap-select
# Reduce mode-switch lag (default is 400ms)
export KEYTIMEOUT=15

export EDITOR="{{EDITOR}}"
export TERM="{{TERM}}"
export HISTSIZE={{HISTSIZE}}
export SAVEHIST={{HISTSIZE}}

export PATH="$HOME/.local/bin:$PATH"

# Disable gh pager (e.g. gh pr list outputs directly, no less/more)
export GH_PAGER=""

# ── Aliases ─────────────────────────────────────────────────────────────────

# BEGIN lfg aliases
alias prs='gh pr list'
alias prv='gh pr view'
alias prco='gh pr checkout'
alias prm='gh pr merge --squash --delete-branch'
alias prmr='gh pr merge --rebase --delete-branch'
alias prc='gh pr create --fill'
alias activate='source .venv/bin/activate'
# END lfg aliases

myaliases() {
    echo "── Custom (lfg) ──"
    sed -n '/^# BEGIN lfg aliases/,/^# END lfg aliases/p' ~/.zshrc \
        | grep -E '^alias ' \
        | sed 's/^alias /  /'
    echo ""
    echo "── Git (oh-my-zsh plugin) ──"
    cat <<'GITEOF'
  gst     git status
  gss     git status --short
  gd      git diff
  gds     git diff --staged
  ga      git add
  gaa     git add --all
  gcmsg   git commit --message
  gl      git pull
  gp      git push
  gpsup   git push --set-upstream origin (current branch)
  gco     git checkout
  gcb     git checkout -b
  gcm     git checkout main
  gsw     git switch
  gswc    git switch --create
  gb      git branch
  gbd     git branch --delete
  glo     git log --oneline --decorate
  gsta    git stash push
  gstp    git stash pop
  gstl    git stash list
  grbi    git rebase --interactive
  grbm    git rebase main
  grt     cd to repo root
  gcp     git cherry-pick
  gsh     git show
GITEOF
    echo ""
    echo "Full list: alias | grep '^g'"
}

myvim() {
    cat <<'EOF'
── Movement ──
  h/j/k/l     left/down/up/right
  w / b       next / prev word
  e           end of word
  0 / $       start / end of line
  gg / G      top / bottom of file
  { / }       prev / next paragraph
  Ctrl-d/u    half-page down / up
  %           jump to matching bracket

── Editing ──
  i / a       insert before / after cursor
  I / A       insert at start / end of line
  o / O       new line below / above
  x           delete char
  dd          delete line
  D           delete to end of line
  cc          change line
  C           change to end of line
  ciw         change inner word
  ci" ci( ci{ change inside quotes/parens/braces
  yy          yank (copy) line
  p / P       paste after / before
  u           undo
  Ctrl-r      redo
  .           repeat last command

── Visual Mode ──
  v           visual (char)
  V           visual (line)
  Ctrl-v      visual (block)
  > / <       indent / outdent selection

── Search ──
  /pattern    search forward
  ?pattern    search backward
  n / N       next / prev match
  *           search word under cursor

── Files & Buffers ──
  :w          save
  :q          quit
  :wq / ZZ    save + quit
  :q!         quit without saving
  :e file     open file
  :bn / :bp   next / prev buffer

── Power Moves ──
  dd p        move a line (cut + paste)
  xp          swap two characters
  daw         delete a word (incl. space)
  gUiw/guiw   uppercase/lowercase word
  :%s/a/b/g   replace all a with b
  :!cmd       run shell command
  qa...q @a   record macro a, replay it
EOF
}
