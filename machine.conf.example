# machine.conf -- Per-machine overrides (gitignored)
# Copy this file to machine.conf and customize for this machine.
#
# Any variable defined here overrides the value in defaults.conf.
# All variables are prefixed with DOTS_ and referenced in templates
# without the prefix: DOTS_EDITOR -> {{EDITOR}} in templates.

# DOTS_GIT_NAME="Your Name"
# DOTS_GIT_EMAIL="you@example.com"
# DOTS_EDITOR="nvim"
# DOTS_SHELL="zsh"
# DOTS_TERM="xterm-256color"
# DOTS_ZSH_THEME="agnoster"
# DOTS_ZSH_PLUGINS="git docker z kubectl"
# DOTS_TMUX_PREFIX="C-a"
# DOTS_TMUX_SHELL="/usr/local/bin/zsh"
# DOTS_PATH_EXTRA="/opt/homebrew/bin:/usr/local/go/bin"
# DOTS_HISTSIZE="50000"
# DOTS_GIT_CREDENTIAL_HELPER="cache"  # use "cache" on linux, "osxkeychain" on mac
# DOTS_CLAUDE_PERMISSIONS_ALLOW='["Bash", "Read", "Edit", "Write", "Glob", "Grep"]'
# DOTS_CLAUDE_MODEL="claude-opus-4-6"
